<script>
  // SCROLL REVEAL
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); } });
  }, { threshold: 0.12 });
  reveals.forEach(el => observer.observe(el));

  // OBJECTION ACCORDION
  function toggleObj(header) {
    const item = header.parentElement;
    const isOpen = item.classList.contains('open');
    document.querySelectorAll('.obj-item').forEach(i => i.classList.remove('open'));
    if (!isOpen) item.classList.add('open');
  }

  // PROGRAM MONTHS
  const months = [
    {
      label: 'Month 1 — Foundation',
      title: 'BUILD YOUR CONFIDENCE',
      body: 'You start by removing hesitation. Through daily speaking drills and pronunciation work, you go from avoiding English conversations to actively seeking them out in every professional setting.',
      list: ['Pronunciation & fluency drills', 'Everyday workplace vocabulary', 'Speaking under time pressure', 'Peer role-play scenarios', 'Month 1 game challenge']
    },
    {
      label: 'Month 2 — Business English',
      title: 'TALK LIKE A PROFESSIONAL',
      body: 'You handle meetings, emails, and workplace conversations with ease. You learn to present ideas clearly, ask smart questions, and respond confidently under pressure — with a game-based challenge to lock in progress.',
      list: ['Meetings & presentations', 'Professional email writing', 'Workplace negotiations', 'Cold networking conversations', 'Month 2 game challenge']
    },
    {
      label: 'Month 3 — Mastery',
      title: 'READY FOR YOUR NEXT LEVEL',
      body: 'You simulate job interviews, client calls, and high-stakes negotiations. You graduate with fluency in professional English, a full communication toolkit, and the confidence to use it every single day.',
      list: ['Job interview simulation', 'Client & stakeholder calls', 'Salary negotiation role-play', 'Leadership communication', 'Final challenge & graduation']
    }
  ];

  function selectMonth(idx, el) {
    document.querySelectorAll('.month-card').forEach(c => c.classList.remove('active'));
    el.classList.add('active');
    const m = months[idx];
    document.getElementById('d-label').textContent = m.label;
    document.getElementById('d-title').textContent = m.title;
    document.getElementById('d-body').textContent = m.body;
    const list = document.getElementById('d-list');
    list.innerHTML = m.list.map(i => `<li>${i}</li>`).join('');
    const detail = document.getElementById('program-detail');
    detail.style.opacity = '0'; detail.style.transform = 'translateY(10px)';
    setTimeout(() => { detail.style.transition = 'opacity .3s, transform .3s'; detail.style.opacity = '1'; detail.style.transform = 'none'; }, 20);
  }
</script>
